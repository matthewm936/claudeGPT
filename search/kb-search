#!/usr/bin/env bash
# Semantic search over the KB. Wraps search.py with venv activation.
# Self-bootstrapping: first run creates the venv and installs dependencies.
#
# Usage:
#   ./search/kb-search "feeling isolated"          # search
#   ./search/kb-search --build                     # rebuild index
#   ./search/kb-search --build "query"             # rebuild then search
#   ./search/kb-search "query" --top 10            # more results

DIR="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$DIR/.." && pwd)"
VENV="$REPO/.venv"

if [ ! -d "$VENV" ]; then
    echo "First run — setting up semantic search..."
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install --quiet -r "$DIR/requirements.txt"
    echo "Done. Ready to search."
    echo ""
fi

source "$VENV/bin/activate"
exec python "$DIR/search.py" "$@"
